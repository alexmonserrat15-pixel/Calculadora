@model Calculadora.MVC.Models.EnvioViewModel

@{
    ViewData["Title"] = "Calculadora de Envíos";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="text-center mb-4">Calculadora de Tarifas de Envío</h2>

            <div class="card shadow">
                <div class="card-body p-4">
                    <form asp-action="Index" method="post">

                        <div class="mb-3">
                            <label class="form-label fw-bold">País de destino</label>
                            <select asp-for="pais_nombre" class="form-select">
                                <option value="">Selecciona un país...</option>
                                @foreach (var pais in Model.Paises)
                                {
                                    <option value="@pais">@pais</option>
                                }
                            </select>
                            <span asp-validation-for="pais_nombre" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Peso del paquete (kg)</label>
                            <input asp-for="peso" type="number" class="form-control"
                                   placeholder="Ej: 10" min="0.1" step="0.1"/>
                            <span asp-validation-for="peso" class="text-danger"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                Calcular tarifa
                            </button>
                        </div>

                    </form>
                </div>
            </div>

            @if (Model.MostrarResultado)
            {
                <div class="card shadow mt-4 border-primary">
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">Resultado</h5>
                        <p>País: <strong>@Model.pais_nombre</strong></p>
                        <p>Peso: <strong>@Model.peso kg</strong></p>
                        <p>Tarifa por kg: <strong>@Model.tarifa_usd USD</strong></p>
                        <hr/>
                        <h5 class="text-primary">
                            Costo total: <strong>@Model.costo_total USD</strong>
                        </h5>
                    </div>
                </div>
            }

        </div>
    </div>
</div>
