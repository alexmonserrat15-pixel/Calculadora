@model IEnumerable<Calculadora.Domain.Entities.Tasa>

@{
    ViewData["Title"] = "Panel de Administración";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3>Panel de Administración</h3>
            <small class="text-muted">Bienvenido, <strong>@ViewBag.Usuario</strong></small>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Crear" class="btn btn-success">+ Agregar país</a>
            <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-danger">Cerrar sesión</a>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>País</th>
                        <th>Tarifa (USD/kg)</th>
                        <th>Creado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tasa in Model)
                    {
                        <tr>
                            <td>@tasa.id    </td>
                            <td>@tasa.pais_nombre</td>
                            <td>$@tasa.tarifa_usd</td>
                            <td>@tasa.creado_en.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a asp-action="Editar" asp-route-id="@tasa.id"
                                   class="btn btn-sm btn-warning">Editar</a>

                                <form asp-action="Eliminar" method="post" class="d-inline"
                                      onsubmit="return confirm('¿Eliminar este país?')">
                                    <input type="hidden" name="id" value="@tasa.id"/>
                                    <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <a href="/" class="text-muted small">← Volver a la calculadora</a>
    </div>
</div>