@model Calculadora.Domain.Entities.Tasa

@{
    ViewData["Title"] = "Agregar país";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <h4 class="mb-4">Agregar nuevo país</h4>

            <div class="card shadow">
                <div class="card-body p-4">

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    <form asp-action="Crear" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">País</label>
                            <input asp-for="pais_nombre" class="form-control"
                                   placeholder="Ej: Francia"/>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tarifa (USD por kg)</label>
                            <input asp-for="tarifa_usd" type="number" step="0.01"
                                   class="form-control" placeholder="Ej: 12.00"/>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Guardar</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>
